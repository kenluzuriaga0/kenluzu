---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  id: string;
  title: string;
  shortDescription: string;
  image: ImageMetadata | string;
  imageAlt: string;
  techTags: string[];
  href: string;
  lang?: 'en' | 'es';
}

const { id, title, shortDescription, image, imageAlt, techTags, href, lang = 'en' } = Astro.props;

const labels = {
  en: {
    sourceCode: 'Source Code',
    liveDemo: 'Live Demo',
  },
  es: {
    sourceCode: 'Código Fuente',
    liveDemo: 'Ver Proyecto',
  },
};

const t = labels[lang];

// Determinar si es GitHub o proyecto live
const isGitHub = href.includes('github.com');
const linkText = isGitHub ? t.sourceCode : t.liveDemo;
---

<div class="group bg-white dark:bg-gray-900 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300">
  <!-- Image Container -->
  <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 dark:bg-gray-800">
    {typeof image === 'string' ? (
      <img 
        src={image} 
        alt={imageAlt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <Image 
        src={image} 
        alt={imageAlt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    )}
  </div>
  
  <!-- Content -->
  <div class="px-5" >
    <!-- Tech Tags -->
    
    
    <!-- Title -->
    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4 mt-2">{title}</h3>
    
    <!-- Description -->
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-6 line-clamp-3 leading-relaxed">{shortDescription}</p>
    
    <!-- Links -->
    <div class="flex items-center gap-4 mb-3">
      <a 
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-secondary transition-colors"
      >
        {isGitHub ? (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        ) : (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
        )}
        {linkText}
      </a>
      
      <button 
        type="button"
        data-modal-open={`modal-${id}`}
        class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        {lang === 'es' ? 'Detalles' : 'Details'}
      </button>
    </div>
  </div>
</div>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

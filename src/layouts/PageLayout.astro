---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import type { MetaData } from '~/types';
import type { Language } from '~/i18n';
import { getTranslations, getAlternateLanguageUrl } from '~/i18n';

export interface Props {
  metadata?: MetaData;
  lang?: Language;
}

const { metadata, lang = 'en' } = Astro.props;

const t = getTranslations(lang);
const currentPath = Astro.url.pathname;
const alternateUrl = getAlternateLanguageUrl(currentPath);

const footerData = {
  links: [],
  secondaryLinks: [],
  socialLinks: [
    { ariaLabel: 'X', icon: 'tabler:brand-x', href: 'https://x.com/ken_luzuriaga' },
    { ariaLabel: 'Instagram', icon: 'tabler:brand-instagram', href: 'https://www.instagram.com/ken_nlm' },
    { ariaLabel: 'Github', icon: 'tabler:brand-github', href: 'https://github.com/kenluzuriaga0' },
  ],
  footNote: t.footer.madeBy,
};
---

<Layout metadata={metadata}>
  <slot name="header">
    <Header
      lang={lang}
      links={[
        { text: t.nav.home, href: lang === 'en' ? '/' : '/es' },
        { text: t.nav.blog, href: lang === 'en' ? '/blog' : '/es/blog' },
        { text: t.nav.about, href: lang === 'en' ? '/#about' : '/es/#about' },
        { text: t.nav.resume, href: lang === 'en' ? '/#resume' : '/es/#resume' },
        { text: t.nav.portfolio, href: lang === 'en' ? '/#portfolio' : '/es/#portfolio' },
      ]}
      actions={[
        {
          text: t.nav.hireMe,
          href: '#',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>
</Layout>
